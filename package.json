{
  "name": "@nuraly/lumenjs",
  "version": "0.1.3",
  "description": "Full-stack Lit web component framework with file-based routing, server loaders, SSR, and API routes",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "lumenjs": "dist/cli.js"
  },
  "exports": {
    ".": "./dist/cli.js",
    "./db": "./dist/db/index.js"
  },
  "files": [
    "dist",
    "templates",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepublishOnly": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "lit",
    "web-components",
    "ssr",
    "vite",
    "framework",
    "file-based-routing",
    "loaders",
    "api-routes",
    "hydration"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Nuralyio/lumenjs.git"
  },
  "homepage": "https://github.com/Nuralyio/lumenjs",
  "bugs": {
    "url": "https://github.com/Nuralyio/lumenjs/issues"
  },
  "author": "labidiaymen <labidi@aymen.co>",
  "license": "MIT",
  "dependencies": {
    "@lit-labs/ssr": "^3.2.0",
    "better-sqlite3": "^11.0.0",
    "glob": "^10.3.0",
    "lit": "^3.1.0",
    "vite": "^5.4.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^20.19.37",
    "@vitest/coverage-v8": "^4.0.18",
    "ts-morph": "^27.0.2",
    "typescript": "^5.4.5",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "ts-morph": ">=20.0.0"
  },
  "peerDependenciesMeta": {
    "ts-morph": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18"
  }
}
