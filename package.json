{
  "name": "@nuraly/lumenjs",
  "version": "0.5.0",
  "description": "Full-stack Lit web component framework with file-based routing, server loaders, SSR, and API routes",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "lumenjs": "dist/cli.js"
  },
  "files": [
    "dist",
    "templates",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepublishOnly": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "lit",
    "web-components",
    "ssr",
    "vite",
    "framework",
    "file-based-routing",
    "loaders",
    "api-routes",
    "hydration"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Nuralyio/lumenjs.git"
  },
  "homepage": "https://github.com/Nuralyio/lumenjs",
  "bugs": {
    "url": "https://github.com/Nuralyio/lumenjs/issues"
  },
  "author": "labidiaymen <labidi@aymen.co>",
  "license": "MIT",
  "dependencies": {
    "@lit-labs/ssr": "^3.2.0",
    "glob": "^10.2.1",
    "lit": "^3.1.0",
    "vite": "^5.4.0"
  },
  "peerDependencies": {
    "@aws-sdk/client-s3": "^3.0.0",
    "@aws-sdk/s3-request-presigner": "^3.0.0",
    "better-sqlite3": "^12.8.0",
    "codejar": "^4.2.0",
    "otplib": "^12.0.0",
    "pg": "^8.0.0",
    "qrcode": "^1.5.0",
    "socket.io": "^4.0.0",
    "socket.io-client": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "@aws-sdk/client-s3": {
      "optional": true
    },
    "@aws-sdk/s3-request-presigner": {
      "optional": true
    },
    "better-sqlite3": {
      "optional": true
    },
    "codejar": {
      "optional": true
    },
    "pg": {
      "optional": true
    },
    "socket.io": {
      "optional": true
    },
    "socket.io-client": {
      "optional": true
    },
    "otplib": {
      "optional": true
    },
    "qrcode": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.14.2",
    "@types/qrcode": "^1.5.6",
    "@vitest/coverage-v8": "^4.0.18",
    "otplib": "^12.0.1",
    "qrcode": "^1.5.4",
    "typescript": "^5.4.5",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=18"
  }
}
